{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Nice Chinese Chess",
  "version": "0.1.0",
  "identifier": "com.nicechchess.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "雅弈象棋",
        "width": 800,
        "height": 600,
        "devtools": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": false,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "../assets/**/*"
    ]
  }  
}
